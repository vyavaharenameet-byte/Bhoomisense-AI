# ===========================================================================
# BhoomiSense backend — environment variables
# Copy to `.env` (cd backend && cp .env.example .env). Every service below is
# FREE and most need NO key — the defaults work out of the box.
# ===========================================================================

ENVIRONMENT=development

# Comma-separated list of frontends allowed to call this API (CORS).
# In production set this to your Vercel URL, e.g. https://bhoomisense.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# OpenStreetMap requires a real, identifying User-Agent. Put a contact here.
USER_AGENT=BhoomiSenseAI/1.0 (contact: your-email@example.com)

# Where the trained .joblib models live (relative to backend/).
MODELS_DIR=app/models

# --- Optional services -----------------------------------------------------
# Only needed if you wire up history persistence / caching (see ARCHITECTURE.md).
# Supabase gives a free Postgres; Redis can run locally or on Upstash free tier.
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/bhoomisense
# REDIS_URL=redis://localhost:6379/0

# Optional fallback weather provider (free tier, 60 calls/min).
# OPENWEATHER_API_KEY=

# HTTP tuning
HTTP_TIMEOUT_SECONDS=12
CACHE_TTL_SECONDS=1800
